{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentspec.dev/schemas/agent-manifest/0.1.json",
  "title": "AgentManifest",
  "description": "The @agentspec/core agent manifest schema. Generated from model AgentManifest in lib/main.tsp.",
  "type": "object",
  "required": ["specVersion", "id", "description", "sensitivity", "behavior", "runtime", "communication"],
  "properties": {
    "$schema": { "type": "string" },
    "specVersion": {
      "type": "string",
      "description": "Protocol version ΓÇö bumps only on breaking schema changes. Distinct from package semver."
    },
    "id": { "type": "string" },
    "description": { "type": "string" },
    "role": { "type": "string" },
    "agentVersion": { "type": "string" },
    "sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "restricted"],
      "default": "internal"
    },
    "behavior": {
      "type": "object",
      "required": ["capabilities"],
      "properties": {
        "instructions": { "type": "string" },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "level": { "type": "string" }
            }
          }
        },
        "boundaries": {
          "type": "object",
          "required": ["handles", "doesNotHandle"],
          "properties": {
            "handles": { "type": "string" },
            "doesNotHandle": { "type": "string" }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "required": ["tools", "knowledge", "memory"],
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "knowledge": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source"],
            "properties": {
              "source": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "memory": {
          "type": "string",
          "enum": ["none", "session", "persistent", "shared"]
        }
      }
    },
    "communication": {
      "type": "object",
      "required": ["conversationStarters", "inputModes", "outputModes"],
      "properties": {
        "conversationStarters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inputModes": {
          "type": "array",
          "items": { "type": "string", "enum": ["text", "file", "image", "audio", "structured"] }
        },
        "outputModes": {
          "type": "array",
          "items": { "type": "string", "enum": ["text", "file", "image", "audio", "structured", "stream"] }
        }
      }
    }
  },
  "additionalProperties": false,
  "$comment": "This schema is generated from model AgentManifest in lib/main.tsp. Do not edit by hand ΓÇö regenerate with: tsp compile --emit @typespec/json-schema"
}